# EduPlatform environment variables

# Database (SQLite for dev, Postgres URL for prod)
DATABASE_URL="file:./db/custom.db"

# Public app URL (used for OG tags, CORS, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (https://resend.com) — email OTP delivery
# In dev, leave blank to print OTPs to server log
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"

# Groq (https://console.groq.com) — AI question generation
# In dev, leave blank to use mock questions
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# For prod (when migrating off SQLite)
# DATABASE_URL="postgresql://user:pass@host:5432/eduplatform"
# REDIS_URL="redis://host:6379"
