{
  "family": "eduplatform-web",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::755395261031:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::755395261031:role/ecsTaskExecutionRole",
  "cpu": "512",
  "memory": "1024",
  "requiresCompatibilities": ["FARGATE"],
  "containerDefinitions": [
    {
      "name": "eduplatform-web",
      "image": "755395261031.dkr.ecr.ap-south-1.amazonaws.com/eduplatform-web:latest",
      "cpu": 512,
      "memory": 1024,
      "memoryReservation": 768,
      "portMappings": [{"containerPort": 3000, "protocol": "tcp"}],
      "essential": true,
      "environment": [
        {"name": "NODE_ENV", "value": "production"},
        {"name": "DATABASE_URL", "value": "postgresql://eduplatform:yAIyW2Y0809ZGYFPTyFHqc84uesuXX8u@eduplatform-db.clkk64yekaq9.ap-south-1.rds.amazonaws.com:5432/eduplatform"},
        {"name": "NEXT_PUBLIC_APP_URL", "value": "https://dreamkoreasmartclass.com"},
        {"name": "GROQ_MODEL", "value": "llama-3.3-70b-versatile"}
      ],
      "secrets": [
        {"name": "RESEND_API_KEY", "valueFrom": "arn:aws:ssm:ap-south-1:755395261031:parameter/eduplatform/resend-api-key"},
        {"name": "GROQ_API_KEY", "valueFrom": "arn:aws:ssm:ap-south-1:755395261031:parameter/eduplatform/groq-api-key"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eduplatform-web",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
