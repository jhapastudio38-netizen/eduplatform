{
  "appId": "app.eduplatform.mobile",
  "appName": "EduPlatform",
  "webDir": "./out",
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor",
    "hostname": "app.eduplatform.app",
    "url": "https://app.eduplatform.app"
  },
  "backgroundColor": "#10b981",
  "loggingBehavior": "production",
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#10b981",
    "buildOptions": {
      "keystorePath": "release.keystore",
      "keystoreAlias": "eduplatform",
      "keystoreAliasPassword": "",
      "keystorePassword": ""
    }
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#10b981",
    "scrollEnabled": true,
    "limitsNavigationsToAppBoundDomains": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#10b981",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "iosSpinnerStyle": "small",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#10b981",
      "sound": "bell.wav"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "cordova": {}
}
