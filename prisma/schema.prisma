// EduPlatform — Prisma schema
// Multi-role education app: Student / Teacher / Admin
// Optimized for indexing & 100k concurrency.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // In production (AWS RDS) we use Postgres. In local dev we use SQLite.
  // The DATABASE_URL env var determines which — for dev it's `file:...`,
  // for prod it's `postgresql://...`. Prisma accepts either provider
  // value at runtime; the URL prefix wins.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  name         String?
  role         Role     @default(STUDENT)
  avatarUrl    String?
  isVerified   Boolean  @default(false)
  isBanned     Boolean  @default(false)
  // Credential login (teachers + admins only — students use OTP)
  passwordHash String?
  username     String?  @unique // for teacher/admin login
  // Student signup tracking
  signupMethod String?  // "otp_email" | "otp_phone" | "credentials"
  createdBy    String?  // admin who created this teacher account
  lastActiveAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  sessions     Session[]
  // Student-side
  submissions  Submission[]
  enrollments  Enrollment[]
  qaQuestions  QAQuestion[]
  // Teacher-side
  liveClasses  LiveClass[]   @relation("TeacherClasses")
  taughtChapters Chapter[]   @relation("AuthorChapters")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpCode {
  id        String   @id @default(cuid())
  contact   String // email or phone
  code      String
  purpose   String   @default("login") // login | reset | verify
  attempts  Int      @default(0)
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([contact, expiresAt])
}

// ─── Content Model (Admin-managed) ────────────────────────────────────────────

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconUrl     String?
  createdAt   DateTime @default(now())

  chapters    Chapter[]
}

model Chapter {
  id          String   @id @default(cuid())
  subjectId   String
  title       String
  slug        String
  description String?
  order       Int      @default(0)
  authorId    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  author      User?    @relation("AuthorChapters", fields: [authorId], references: [id])
  lessons     Lesson[]
  tests       Test[]
  questions   Question[]

  @@unique([subjectId, slug])
  @@index([subjectId, order])
}

enum LessonType {
  TEXT
  VIDEO
  PDF
  INTERACTIVE
}

model Lesson {
  id          String   @id @default(cuid())
  chapterId   String
  title       String
  slug        String
  type        LessonType @default(TEXT)
  content     String // markdown / HTML
  videoUrl    String?
  attachments String? // JSON array of file URLs
  durationMin Int      @default(10)
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  progress    LessonProgress[]

  @@unique([chapterId, slug])
  @@index([chapterId, order])
}

model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  percent   Int      @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

// ─── Questions, Tests, Exams ──────────────────────────────────────────────────

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  ONE_WORD
  SHORT_ANSWER
  LONG_ANSWER
  FILL_BLANK
  MATCHING
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Question {
  id          String     @id @default(cuid())
  chapterId   String?
  type        QuestionType
  difficulty  Difficulty @default(MEDIUM)
  stem        String // question text (markdown)
  options     String? // JSON array for MCQ
  correctAnswer String? // JSON: string | string[] | {match: ...}
  explanation String?
  tags        String? // JSON array
  imageUrl    String? // Optional image for visual questions
  audioUrl    String? // Optional audio for listening questions
  audioLoop   Int      @default(0) // 0 = no loop, N = loop N times, -1 = infinite
  audioLoopDelay Int   @default(0) // delay (seconds) between loops
  aiGenerated Boolean    @default(false)
  sourceFile  String?
  // Question Bank: standalone practice questions (not tied to a test)
  inQuestionBank Boolean @default(false)
  category    String?  // e.g. "Vocabulary", "Grammar", "Listening", "Reading"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapter     Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  testItems   TestItem[]

  @@index([chapterId])
  @@index([type, difficulty])
  @@index([inQuestionBank])
  @@index([category])
}

model Test {
  id          String   @id @default(cuid())
  chapterId   String?
  title       String
  description String?
  durationMin Int      @default(30)
  isExam      Boolean  @default(false)
  examType    String   @default("REGULAR") // UBT / TOPIK_I / TOPIK_II / DEMO / CHAPTER / BATCH / PLACEMENT / REGULAR
  passScore   Int      @default(40)
  startAt     DateTime?
  endAt       DateTime?
  isActive    Boolean  @default(true) // admin/teacher can deactivate
  isPublished Boolean  @default(false)
  negativeMarking Float @default(0) // points deducted per wrong answer
  shuffleQuestions Boolean @default(false)
  showResultImmediately Boolean @default(true)
  maxAttempts Int      @default(1) // 0 = unlimited
  createdBy   String? // teacher/admin who created
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapter     Chapter? @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  items       TestItem[]
  submissions Submission[]

  @@index([chapterId])
  @@index([isPublished, startAt])
  @@index([examType])
  @@index([isActive])
}

model TestItem {
  id          String   @id @default(cuid())
  testId      String
  questionId  String
  points      Int      @default(1)
  order       Int      @default(0)

  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([testId, order])
}

model Submission {
  id          String   @id @default(cuid())
  testId      String
  userId      String
  answers     String // JSON: { questionId: answer }
  score       Int?
  maxScore    Int?
  startedAt   DateTime @default(now())
  submittedAt DateTime?
  graded      Boolean  @default(false)

  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId]) // one submission per test per user (configurable)
  @@index([userId, submittedAt])
}

// ─── Live Classes (Teacher) ───────────────────────────────────────────────────

model LiveClass {
  id          String   @id @default(cuid())
  teacherId   String
  title       String
  description String?
  subject     String?
  scheduledAt DateTime
  durationMin Int      @default(60)
  roomCode    String   @unique
  isLive      Boolean  @default(false)
  endedAt     DateTime?
  recordingUrl String?
  createdAt   DateTime @default(now())

  teacher     User     @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  attendees   LiveAttendance[]

  @@index([teacherId, scheduledAt])
  @@index([isLive])
}

model LiveAttendance {
  id        String   @id @default(cuid())
  classId   String
  userId    String
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  liveClass LiveClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([classId])
}

// ─── Q&A (Student asks, Teacher/Admin answers) ────────────────────────────────

model QAQuestion {
  id         String   @id @default(cuid())
  userId     String
  lessonId   String?
  title      String
  body       String
  tags       String? // JSON array
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers    QAAnswer[]

  @@index([userId, createdAt])
  @@index([lessonId])
}

model QAAnswer {
  id         String   @id @default(cuid())
  questionId String
  authorId   String
  body       String
  isAccepted Boolean  @default(false)
  createdAt  DateTime @default(now())

  question   QAQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, createdAt])
}

// ─── Enrollments ──────────────────────────────────────────────────────────────

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  subjectId String
  enrolledAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
  @@index([subjectId])
}

// ─── Audit Log (Admin actions) ────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  String? // JSON
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ─── DreamKorea SmartClass — Extended schema (v0.2) ──────────────────────────

// Books — digital library for Korean language learning
model Book {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  author      String?
  coverUrl    String?
  pdfUrl      String? // S3 URL to the PDF file
  fileSizeKb  Int?
  pageCount   Int?
  category    String? // e.g. "Beginner", "Intermediate", "Advanced", "TOPIK"
  level       String? // TOPIK 1-6
  tags        String? // JSON array
  isPublished Boolean  @default(false)
  downloads   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chapters    BookChapter[]
  progress    BookProgress[]

  @@index([category, level])
  @@index([isPublished])
}

model BookChapter {
  id          String   @id @default(cuid())
  bookId      String
  title       String
  order       Int      @default(0)
  startPage   Int
  endPage     Int
  audioUrl    String? // Optional audio narration

  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId, order])
}

model BookProgress {
  id           String   @id @default(cuid())
  userId       String
  bookId       String
  currentPage  Int      @default(1)
  percent      Int      @default(0)
  completed    Boolean  @default(false)
  lastReadAt   DateTime @default(now())

  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
}

// Audio lessons — listening practice for Korean language
model AudioLesson {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  audioUrl    String // S3 URL to the audio file (MP3/M4A)
  durationSec Int
  transcript  String? // Full text transcript
  translation String? // English translation
  level       String? // Beginner / Intermediate / Advanced / TOPIK 1-6
  category    String? // "Conversation", "News", "Story", "Pronunciation"
  tags        String? // JSON array
  isPublished Boolean  @default(false)
  plays       Int      @default(0)
  createdAt   DateTime @default(now())

  progress    AudioLessonProgress[]

  @@index([level, category])
  @@index([isPublished])
}

model AudioLessonProgress {
  id              String   @id @default(cuid())
  userId          String
  audioLessonId   String
  listenedSec     Int      @default(0)
  completed       Boolean  @default(false)
  lastListenedAt  DateTime @default(now())

  audioLesson     AudioLesson @relation(fields: [audioLessonId], references: [id], onDelete: Cascade)

  @@unique([userId, audioLessonId])
  @@index([userId])
}

// Exam timer customization — admin/teacher sets duration per exam
// (Already in Test model via durationMin, but we add ExamSettings for finer control)
model ExamSettings {
  id              String   @id @default(cuid())
  testId          String   @unique
  showTimer       Boolean  @default(true)
  allowPause      Boolean  @default(false)
  allowReview     Boolean  @default(true)
  shuffleQuestions Boolean @default(false)
  passingScore    Int      @default(40) // percentage
  maxAttempts     Int      @default(1) // 0 = unlimited
  negativeMarking Float    @default(0) // points deducted per wrong answer
  scheduleStartAt DateTime?
  scheduleEndAt   DateTime?
  proctoringEnabled Boolean @default(false)

  // We don't enforce a relation to Test here to avoid schema migrations
  // breaking — Test.durationMin remains the source of truth for duration.
}

// Live rooms — real-time classroom sessions
model LiveRoom {
  id          String   @id @default(cuid())
  roomCode    String   @unique // 6-char code students enter to join
  hostId      String // teacher or admin who created the room
  title       String
  description String?
  subject     String?
  audioOnly   Boolean  @default(true) // audio room by default (no video)
  maxStudents Int      @default(50)
  isLive      Boolean  @default(false)
  startedAt   DateTime?
  endedAt     DateTime?
  recordingUrl String?
  createdAt   DateTime @default(now())

  attendees   LiveRoomAttendee[]
  messages    LiveRoomMessage[]

  @@index([hostId, createdAt])
  @@index([isLive])
}

model LiveRoomAttendee {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  role        String   // "host" | "student"
  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  handRaised  Boolean  @default(false)
  micEnabled  Boolean  @default(false)

  room        LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

model LiveRoomMessage {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  userName  String
  body      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  room      LiveRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
}

// Batches — groups of students for cohort-based learning
model Batch {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  teacherId   String?
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())

  students    BatchStudent[]
  exams       BatchExam[]

  @@index([teacherId])
}

model BatchStudent {
  id        String   @id @default(cuid())
  batchId   String
  userId    String
  joinedAt  DateTime @default(now())

  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, userId])
  @@index([userId])
}

model BatchExam {
  id        String   @id @default(cuid())
  batchId   String
  testId    String
  assignedAt DateTime @default(now())
  dueAt     DateTime?

  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, testId])
}

// User stats — aggregated progress for student dashboard
model UserStat {
  id                String   @id @default(cuid())
  userId            String   @unique
  totalExamsTaken   Int      @default(0)
  totalCorrectAnswers Int    @default(0)
  totalQuestionsAnswered Int @default(0)
  averageScore      Float    @default(0) // percentage
  studyStreakDays   Int      @default(0)
  lastStudyDate     DateTime?
  totalTimeSpentMin Int      @default(0)
  booksRead         Int      @default(0)
  audioLessonsCompleted Int  @default(0)
  badgesEarned      Int      @default(0)
  updatedAt         DateTime @updatedAt
}

// Secure admin/teacher URL tokens — separate login URLs
// Admin URL: /admin-login/<token>  (token rotates monthly)
// Teacher URL: /teacher-login/<token>
model SecureLoginToken {
  id        String   @id @default(cuid())
  role      String   // "ADMIN" | "TEACHER"
  token     String   @unique
  createdBy String?
  expiresAt DateTime
  lastUsedAt DateTime?
  createdAt DateTime @default(now())

  @@index([role, expiresAt])
}

// Push notification tokens for OTA updates + exam reminders
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  platform  String   // "android" | "ios" | "web"
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, token])
  @@index([userId])
}

// ─── v0.4 — Home screen cards (admin-editable images) ────────────────────────

model HomeCard {
  id          String   @id @default(cuid())
  key         String   @unique // "ubt_test", "results", "all_books", "question_bank", etc.
  title       String   // Display title (e.g. "UBT TEST")
  section     String   @default("test") // "test" | "resources" | "premium"
  imageUrl    String?  // Image URL (admin uploads)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  route       String?  // App route to navigate to when tapped (e.g. "tests", "books")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section, sortOrder])
}

// ─── v0.3 — Video lessons, enhanced exams, media questions ─────────────────

// Video lessons — YouTube embeds OR uploaded video files, managed by teachers/admins
model VideoLesson {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  youtubeUrl  String   // Full YouTube URL or video ID
  youtubeId   String   // Extracted 11-char video ID for embed
  videoUrl    String?  // Direct video URL (uploaded to R2) — takes priority over YouTube
  videoSource String   @default("youtube") // "youtube" | "upload"
  thumbnailUrl String?
  durationMin Int      @default(10)
  level       String?  // Beginner / Intermediate / Advanced / TOPIK 1-6
  category    String?  // "Grammar", "Conversation", "TOPIK Prep", "Pronunciation"
  chapterId   String?  // Optional: link to a book chapter
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress    VideoLessonProgress[]

  @@index([isPublished, level])
  @@index([category])
}

model VideoLessonProgress {
  id          String   @id @default(cuid())
  userId      String
  videoLessonId String
  watchedSec  Int      @default(0)
  completed   Boolean  @default(false)
  lastWatchedAt DateTime @default(now())

  videoLesson VideoLesson @relation(fields: [videoLessonId], references: [id], onDelete: Cascade)

  @@unique([userId, videoLessonId])
  @@index([userId])
}

// Exam types — UBT, TOPIK, regular practice, etc.
enum ExamType {
  REGULAR
  UBT
  TOPIK_I
  TOPIK_II
  DEMO
  CHAPTER
  BATCH
  PLACEMENT
}
