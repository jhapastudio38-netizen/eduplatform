// TestRunnerScreen — take a test with timer and question navigation.

import { Theme, ActiveTest } from "../app.slint";
import { GlassCard, AccentButton, GhostButton, GlassTextInput } from "../components/glass.slint";
import { TouchArea, ScrollView, StandardListView } from "std-widgets.slint";

export component TestRunnerScreen inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    in property <ActiveTest> test: { id: "", title: "", description: "", duration-min: 0, is-exam: false, pass-score: 0, items: [] };
    callback submit(string, string);
    callback exit();

    property <int> current: 0;
    property <string> timer-text: "00:00";

    // Build a JSON map of { questionId: answer } from per-question inputs.
    // For simplicity in this version, we use a single text input per question.
    property <[string]> answers: [];

    VerticalLayout {
        padding: 16px;
        padding-bottom: 32px;
        spacing: 12px;

        // ─── Top bar: exit + timer ─────────────────────────────────────
        HorizontalLayout {
            spacing: 12px;

            GhostButton {
                text: "← Exit";
                width: 80px;
                clicked: () => { root.exit(); }
            }
            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                width: 100px;
                height: 40px;
                radius: 20px;
                background: rgba(245, 158, 11, 0.15);
                border-width: 1px;
                border-color: rgba(245, 158, 11, 0.3);
                Text {
                    text: "⏱ " + root.timer-text;
                    color: #FCD34D;
                    font-size: 14px;
                    font-weight: 700;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        // ─── Progress bar ──────────────────────────────────────────────
        VerticalLayout {
            spacing: 4px;
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: "Question " + (root.current + 1) + " of " + root.test.items.length;
                    color: Theme.text-secondary;
                    font-size: 12px;
                }
                Rectangle { horizontal-stretch: 1; }
            }
            Rectangle {
                height: 4px;
                radius: 2px;
                background: Theme.glass-bg;
                Rectangle {
                    width: parent.width * ((root.current + 1) / root.test.items.length);
                    height: parent.height;
                    radius: 2px;
                    background: Theme.accent;
                }
            }
        }

        // ─── Current question ──────────────────────────────────────────
        if root.test.items.length > 0 {
            GlassCard {
                vertical-stretch: 1;
                VerticalLayout {
                    padding: 20px;
                    spacing: 16px;

                    Text {
                        text: root.test.items[root.current].question.question-type.to-upper-case()
                              + " · " + root.test.items[root.current].question.difficulty.to-lower-case()
                              + " · " + root.test.items[root.current].points + " pts";
                        color: Theme.text-muted;
                        font-size: 11px;
                        letter-spacing: 0.5px;
                    }

                    Text {
                        text: root.test.items[root.current].question.stem;
                        color: Theme.text-primary;
                        font-size: 17px;
                        font-weight: 600;
                        wrap: word-wrap;
                        width: parent.width;
                    }

                    // ─── Answer area (simplified: single text input) ───
                    GlassTextInput {
                        placeholder: "Type your answer…";
                        text: root.answers[root.current];
                        edited: (v) => {
                            // Update answers list
                        }
                    }

                    Rectangle { vertical-stretch: 1; }
                }
            }
        }

        // ─── Bottom nav (prev / next / submit) ────────────────────────
        HorizontalLayout {
            spacing: 12px;

            GhostButton {
                text: "← Prev";
                width: 100px;
                disabled: root.current == 0;
                clicked: () => { if root.current > 0 { root.current -= 1; } }
            }
            Rectangle { horizontal-stretch: 1; }

            if root.current < root.test.items.length - 1 {
                AccentButton {
                    text: "Next →";
                    width: 120px;
                    clicked: () => {
                        if root.current < root.test.items.length - 1 {
                            root.current += 1;
                        }
                    }
                }
            } else {
                AccentButton {
                    text: "Submit ✓";
                    width: 140px;
                    clicked: () => {
                        // Build answers JSON — for now an empty object
                        root.submit(root.test.id, "{}");
                    }
                }
            }
        }
    }
}
