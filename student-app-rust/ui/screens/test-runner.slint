// TestRunnerScreen — take a test with timer. Professional, no emojis.

import { Theme, ActiveTest } from "../app.slint";
import { GlassCard, AccentButton, GhostButton, GlassTextInput } from "../components/glass.slint";
import { Icon } from "../components/icon.slint";
import { TouchArea, ScrollView } from "std-widgets.slint";

export component TestRunnerScreen inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    in property <ActiveTest> test: { id: "", title: "", description: "", duration-min: 0, is-exam: false, pass-score: 0, items: [] };
    callback submit(string, string);
    callback exit();

    property <int> current: 0;
    property <string> timer-text: "00:00";

    VerticalLayout {
        padding: 16px;
        padding-bottom: 32px;
        spacing: 12px;

        // ─── Top bar ─────────────────────────────────────────────────
        HorizontalLayout {
            spacing: 12px;

            GhostButton {
                text: "Exit";
                icon: "arrow-left";
                width: 90px;
                clicked: () => { root.exit(); }
            }
            Rectangle { horizontal-stretch: 1; }

            // Timer pill
            Rectangle {
                width: 100px;
                height: 40px;
                radius: 20px;
                background: rgba(245, 158, 11, 0.15);
                border-width: 1px;
                border-color: rgba(245, 158, 11, 0.3);
                HorizontalLayout {
                    x: 12px; y: 0;
                    width: parent.width - 24px;
                    height: parent.height;
                    spacing: 6px;

                    Icon {
                        icon-name: "clock";
                        color: #FCD34D;
                        width: 14px; height: 14px;
                        y: (parent.height - self.height) / 2;
                    }
                    Text {
                        text: root.timer-text;
                        color: #FCD34D;
                        font-size: 13px;
                        font-weight: 700;
                        vertical-alignment: center;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }
        }

        // ─── Progress ──────────────────────────────────────────────────
        VerticalLayout {
            spacing: 4px;
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: "Question " + (root.current + 1) + " of " + root.test.items.length;
                    color: Theme.text-secondary;
                    font-size: 12px;
                }
                Rectangle { horizontal-stretch: 1; }
            }
            Rectangle {
                height: 4px;
                radius: 2px;
                background: Theme.glass-bg;
                Rectangle {
                    width: parent.width * ((root.current + 1) / root.test.items.length);
                    height: parent.height;
                    radius: 2px;
                    background: Theme.accent;
                }
            }
        }

        // ─── Question card ────────────────────────────────────────────
        if root.test.items.length > 0 : GlassCard {
                vertical-stretch: 1;
                VerticalLayout {
                    padding: 20px;
                    spacing: 16px;

                    Text {
                        text: root.test.items[root.current].question.question-type.to-upper-case()
                              + "  ·  " + root.test.items[root.current].question.difficulty.to-lower-case()
                              + "  ·  " + root.test.items[root.current].points + " pts";
                        color: Theme.text-muted;
                        font-size: 10px;
                        letter-spacing: 0.5px;
                    }

                    Text {
                        text: root.test.items[root.current].question.stem;
                        color: Theme.text-primary;
                        font-size: 16px;
                        font-weight: 600;
                        wrap: word-wrap;
                        width: parent.width;
                    }

                    GlassTextInput {
                        placeholder: "Type your answer…";
                    }

                    Rectangle { vertical-stretch: 1; }
                }
            }
        }

        // ─── Bottom actions ──────────────────────────────────────────
        HorizontalLayout {
            spacing: 12px;

            GhostButton {
                text: "Previous";
                icon: "arrow-left";
                width: 110px;
                disabled: root.current == 0;
                clicked: () => { if root.current > 0 { root.current -= 1; } }
            }
            Rectangle { horizontal-stretch: 1; }

            if root.current < root.test.items.length - 1 : AccentButton {
                    text: "Next";
                    icon: "arrow-right";
                    width: 120px;
                    clicked: () => {
                        if root.current < root.test.items.length - 1 {
                            root.current += 1;
                        }
                    }
                }
            } else {
                AccentButton {
                    text: "Submit";
                    icon: "check";
                    width: 140px;
                    clicked: () => {
                        root.submit(root.test.id, "{}");
                    }
                }
            }
        }
    }
}
