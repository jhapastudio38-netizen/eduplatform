// LearnScreen — browse subjects → chapters → lessons.
//
// Uses internal step state (1=subjects, 2=chapters, 3=lessons).
// The parent provides data via properties and the screen requests data
// via callbacks (load-chapters, load-lessons).

import { Theme, SubjectItem, ChapterItem, LessonItem } from "../app.slint";
import { GlassCard, GhostButton, SectionTitle } from "../components/glass.slint";
import { TouchArea, ScrollView } from "std-widgets.slint";

export component LearnScreen inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    in property <[SubjectItem]> subjects: [];
    in property <[ChapterItem]> chapters: [];
    in property <[LessonItem]> lessons: [];

    callback load-chapters(string);
    callback load-lessons(string);
    callback back();

    property <int> step: 1;
    property <string> selected-subject: "";
    property <string> selected-subject-name: "";
    property <string> selected-chapter: "";
    property <string> selected-chapter-name: "";

    ScrollView {
        width: 100%;
        height: 100%;

        VerticalLayout {
            padding: 20px;
            padding-bottom: 110px;
            spacing: 16px;

            // ─── Header with back button ───────────────────────────────
            HorizontalLayout {
                spacing: 12px;

                if root.step > 1 {
                    GhostButton {
                        text: "←";
                        width: 44px;
                        clicked: () => {
                            if root.step == 3 { root.step = 2; }
                            else if root.step == 2 { root.step = 1; }
                        }
                    }
                }

                SectionTitle {
                    text: root.step == 1 ? "Learn"
                        : root.step == 2 ? root.selected-subject-name
                        : root.selected-chapter-name;
                    vertical-alignment: center;
                }
            }

            // ─── Step 1: subjects ────────────────────────────────────────
            if root.step == 1 {
                if root.subjects.length == 0 {
                    EmptyState { message: "No subjects available."; }
                }
                for subject[i] in root.subjects : GlassCard {
                    height: 84px;
                    ta := TouchArea {
                        mouse-cursor: ta.has-hover ? pointer : default;
                        clicked: () => {
                            root.selected-subject = subject.id;
                            root.selected-subject-name = subject.name;
                            root.load-chapters(subject.id);
                            root.step = 2;
                        }
                    }
                    HorizontalLayout {
                        padding: 16px;
                        spacing: 14px;

                        Rectangle {
                            width: 52px;
                            height: 52px;
                            radius: 14px;
                            background: @linear-gradient(135deg, #10B981, #0D9488);
                            Text {
                                text: "📖";
                                font-size: 24px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        VerticalLayout {
                            spacing: 4px;
                            Text {
                                text: subject.name;
                                color: Theme.text-primary;
                                font-size: 16px;
                                font-weight: 600;
                            }
                            Text {
                                text: subject.description;
                                color: Theme.text-secondary;
                                font-size: 12px;
                                overflow: elide;
                                width: parent.width;
                            }
                        }
                    }
                }
            }

            // ─── Step 2: chapters ────────────────────────────────────────
            if root.step == 2 {
                if root.chapters.length == 0 {
                    EmptyState { message: "No chapters published yet."; }
                }
                for chapter[i] in root.chapters : GlassCard {
                    height: 76px;
                    ta := TouchArea {
                        mouse-cursor: ta.has-hover ? pointer : default;
                        clicked: () => {
                            root.selected-chapter = chapter.id;
                            root.selected-chapter-name = chapter.title;
                            root.load-lessons(chapter.id);
                            root.step = 3;
                        }
                    }
                    HorizontalLayout {
                        padding: 16px;
                        spacing: 14px;

                        Rectangle {
                            width: 40px;
                            height: 40px;
                            radius: 10px;
                            background: Theme.glass-bg-strong;
                            Text {
                                text: i + 1;
                                color: Theme.text-primary;
                                font-size: 16px;
                                font-weight: 700;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: chapter.title;
                                color: Theme.text-primary;
                                font-size: 15px;
                                font-weight: 600;
                            }
                            Text {
                                text: chapter.description;
                                color: Theme.text-secondary;
                                font-size: 12px;
                                overflow: elide;
                                width: parent.width;
                            }
                        }
                    }
                }
            }

            // ─── Step 3: lessons ─────────────────────────────────────────
            if root.step == 3 {
                if root.lessons.length == 0 {
                    EmptyState { message: "No lessons in this chapter."; }
                }
                for lesson[i] in root.lessons : GlassCard {
                    height: 72px;
                    ta := TouchArea {
                        mouse-cursor: ta.has-hover ? pointer : default;
                        clicked: () => {
                            // For now, no lesson detail screen — opening is a TODO.
                        }
                    }
                    HorizontalLayout {
                        padding: 16px;
                        spacing: 14px;

                        Rectangle {
                            width: 40px;
                            height: 40px;
                            radius: 10px;
                            background: rgba(16, 185, 129, 0.15);
                            Text {
                                text: lesson.lesson-type == "VIDEO" ? "▶" : "📄";
                                font-size: 18px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                            }
                        }
                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: lesson.title;
                                color: Theme.text-primary;
                                font-size: 15px;
                                font-weight: 500;
                            }
                            Text {
                                text: lesson.duration-min + " min · " + lesson.lesson-type.to-lower-case();
                                color: Theme.text-secondary;
                                font-size: 12px;
                            }
                        }
                    }
                }
            }
        }
    }
}

component EmptyState inherits GlassCard {
    height: 100px;
    property <string> message;
    VerticalLayout {
        alignment: center;
        Text {
            text: root.message;
            color: Theme.text-muted;
            font-size: 14px;
            horizontal-alignment: center;
        }
    }
}
