// ProfileScreen — user info + logout. Professional, no emojis.

import { Theme, UserItem } from "../app.slint";
import { GlassCard, AccentButton, GhostButton, SectionTitle } from "../components/glass.slint";
import { Icon } from "../components/icon.slint";
import { ScrollView } from "std-widgets.slint";

export component ProfileScreen inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    in property <UserItem> user: { id: "", name: "", email: "", role: "STUDENT" };
    callback logout();
    callback back();

    ScrollView {
        width: 100%;
        height: 100%;

        VerticalLayout {
            padding: 20px;
            padding-bottom: 110px;
            spacing: 16px;

            // ─── Avatar + name ────────────────────────────────────────────
            VerticalLayout {
                alignment: center;
                spacing: 8px;

                Rectangle {
                    width: 80px;
                    height: 80px;
                    radius: self.width / 2;
                    background: @linear-gradient(135deg, #10B981, #0D9488);
                    horizontal-stretch: 0;
                    Text {
                        text: root.user.name == "" ? "S" : root.user.name;
                        color: #FFFFFF;
                        font-size: 28px;
                        font-weight: 700;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
                Text {
                    text: root.user.name == "" ? "Student" : root.user.name;
                    color: Theme.text-primary;
                    font-size: 20px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    letter-spacing: -0.3px;
                }
                Text {
                    text: root.user.role.to-lower-case();
                    color: Theme.text-secondary;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }

            // ─── Account info ────────────────────────────────────────────
            Text {
                text: "Account";
                color: Theme.text-primary;
                font-size: 18px;
                font-weight: 700;
                letter-spacing: -0.2px;
            }

            GlassCard {
                VerticalLayout {
                    padding: 18px;
                    spacing: 12px;

                    ProfileRow {
                        icon-name: "mail";
                        label: "Email";
                        value: root.user.email;
                    }
                    Rectangle {
                        height: 1px;
                        background: Theme.glass-border;
                    }
                    ProfileRow {
                        icon-name: "shield";
                        label: "User ID";
                        value: root.user.id;
                    }
                    Rectangle {
                        height: 1px;
                        background: Theme.glass-border;
                    }
                    ProfileRow {
                        icon-name: "user";
                        label: "Role";
                        value: root.user.role;
                    }
                }
            }

            // ─── Achievements ────────────────────────────────────────────
            Text {
                text: "Achievements";
                color: Theme.text-primary;
                font-size: 18px;
                font-weight: 700;
                letter-spacing: -0.2px;
            }
            GlassCard {
                height: 100px;
                HorizontalLayout {
                    padding: 18px;
                    spacing: 16px;
                    alignment: space-around;

                    AchievementItem { icon-name: "flame"; value: "7"; label: "Streak"; icon-color: #FB923C; }
                    AchievementItem { icon-name: "book"; value: "12"; label: "Lessons"; icon-color: #10B981; }
                    AchievementItem { icon-name: "trophy"; value: "3"; label: "Badges"; icon-color: #F59E0B; }
                }
            }

            // ─── Logout ─────────────────────────────────────────────────
            AccentButton {
                text: "Sign out";
                icon: "logout";
                background: Theme.danger;
                clicked: () => { root.logout(); }
            }

            Text {
                text: "EduPlatform v0.1.0";
                color: Theme.text-muted;
                font-size: 11px;
                horizontal-alignment: center;
            }
        }
    }
}

component ProfileRow inherits HorizontalLayout {
    property <string> icon-name;
    property <string> label;
    property <string> value;
    spacing: 10px;
    Icon {
        icon-name: root.icon-name;
        color: Theme.text-secondary;
        width: 16px; height: 16px;
        y: (parent.height - self.height) / 2;
    }
    Text {
        text: root.label;
        color: Theme.text-secondary;
        font-size: 13px;
        vertical-alignment: center;
    }
    Rectangle { horizontal-stretch: 1; }
    Text {
        text: root.value;
        color: Theme.text-primary;
        font-size: 13px;
        font-weight: 600;
        vertical-alignment: center;
        overflow: elide;
        width: 180px;
        horizontal-alignment: right;
    }
}

component AchievementItem inherits VerticalLayout {
    property <string> icon-name;
    property <string> value;
    property <string> label;
    property <color> icon-color: Theme.accent;
    spacing: 4px;
    alignment: center;
    Icon {
        icon-name: root.icon-name;
        color: root.icon-color;
        width: 22px; height: 22px;
        horizontal-stretch: 0;
    }
    Text {
        text: root.value;
        color: Theme.text-primary;
        font-size: 16px;
        font-weight: 700;
        horizontal-alignment: center;
    }
    Text {
        text: root.label;
        color: Theme.text-muted;
        font-size: 11px;
        horizontal-alignment: center;
    }
}
