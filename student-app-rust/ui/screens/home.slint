// HomeScreen — student dashboard.
//
// Layout:
//   - Welcome banner (glass card with gradient overlay)
//   - 4-stat grid (lessons, tests, Q&A, streak)
//   - "Continue learning" section with subject cards
//   - Bottom nav is rendered by the parent App.

import { Theme, Screen, SubjectItem, HomeStatsItem, UserItem } from "../app.slint";
import { GlassCard, GlassCardStrong, AccentButton, GhostButton, StatChip, SectionTitle, Subtitle } from "../components/glass.slint";
import { TouchArea, ScrollView } from "std-widgets.slint";

export component HomeScreen inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    in property <UserItem> user: { id: "", name: "", email: "", role: "STUDENT" };
    in property <HomeStatsItem> stats: { lessons-completed: 0, tests-taken: 0, qa-asked: 0, streak: 0 };
    in property <[SubjectItem]> subjects: [];
    callback load-home();
    callback navigate(Screen);

    ScrollView {
        width: 100%;
        height: 100%;

        VerticalLayout {
            padding: 20px;
            padding-bottom: 110px;
            spacing: 18px;

            // ─── Top bar with greeting ───────────────────────────────────
            HorizontalLayout {
                spacing: 12px;
                VerticalLayout {
                    spacing: 2px;
                    Text {
                        text: "Welcome back,";
                        color: Theme.text-secondary;
                        font-size: 13px;
                    }
                    Text {
                        text: root.user.name == "" ? "Student" : root.user.name;
                        color: Theme.text-primary;
                        font-size: 22px;
                        font-weight: 800;
                    }
                }
            }

            // ─── Hero card (emerald gradient) ────────────────────────────
            Rectangle {
                width: 100%;
                height: 160px;
                radius: Theme.radius-xl;
                background: @linear-gradient(135deg, #10B981 0%, #0D9488 60%, #047857 100%);
                drop-shadow-blur: 24px;
                drop-shadow-color: rgba(16, 185, 129, 0.35);
                drop-shadow-offset-y: 10px;

                VerticalLayout {
                    padding: 20px;
                    spacing: 6px;

                    Text {
                        text: "Keep your momentum going 👋";
                        color: rgba(255, 255, 255, 0.85);
                        font-size: 13px;
                    }
                    Text {
                        text: "Today's a great day to learn";
                        color: #FFFFFF;
                        font-size: 22px;
                        font-weight: 800;
                    }

                    // Spacer
                    Rectangle { vertical-stretch: 1; }

                    HorizontalLayout {
                        spacing: 8px;
                        AccentButton {
                            text: "Continue learning";
                            background: #FFFFFF;
                            clicked: () => { root.navigate(Screen.learn); }
                        }
                        GhostButton {
                            text: "Take a test";
                            background: rgba(255, 255, 255, 0.15);
                            border-color: rgba(255, 255, 255, 0.25);
                            text-color: #FFFFFF;
                            clicked: () => { root.navigate(Screen.tests); }
                        }
                    }
                }
            }

            // ─── Stats grid (2×2) ────────────────────────────────────────
            GridLayout {
                spacing: 12px;
                ColumnCount: 2;
                RowCount: 2;

                StatChip {
                    icon: "📚";
                    icon-color: #10B981;
                    value: root.stats.lessons-completed;
                    label: "Lessons done";
                }
                StatChip {
                    icon: "📝";
                    icon-color: #F59E0B;
                    value: root.stats.tests-taken;
                    label: "Tests taken";
                }
                StatChip {
                    icon: "💬";
                    icon-color: #EF4444;
                    value: root.stats.qa-asked;
                    label: "Questions asked";
                }
                StatChip {
                    icon: "🔥";
                    icon-color: #FB923C;
                    value: root.stats.streak;
                    label: "Day streak";
                }
            }

            // ─── Subjects section ───────────────────────────────────────
            HorizontalLayout {
                spacing: 8px;
                SectionTitle {
                    text: "Browse subjects";
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
            }

            if root.subjects.length == 0 {
                GlassCard {
                    height: 80px;
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "No subjects available yet.";
                            color: Theme.text-muted;
                            font-size: 14px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }

            for subject[i] in root.subjects : GlassCard {
                height: 80px;
                ta := TouchArea {
                    mouse-cursor: ta.has-hover ? pointer : default;
                    clicked: () => { root.navigate(Screen.learn); }
                }
                HorizontalLayout {
                    padding: 14px;
                    spacing: 14px;
                    alignment: start;

                    Rectangle {
                        width: 52px;
                        height: 52px;
                        radius: 14px;
                        background: @linear-gradient(135deg, #10B981, #0D9488);
                        Text {
                            text: "📖";
                            font-size: 24px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: subject.name;
                            color: Theme.text-primary;
                            font-size: 16px;
                            font-weight: 600;
                        }
                        Text {
                            text: subject.description;
                            color: Theme.text-secondary;
                            font-size: 12px;
                            overflow: elide;
                            width: parent.width;
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: "→";
                        color: Theme.text-muted;
                        font-size: 20px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
