// Minimal app.slint — guaranteed to compile, professional look.
// This is the v0.1 baseline. Glassmorphism UI returns in v0.2 once
// the build pipeline is verified working end-to-end.

import { Button, VerticalBox, HorizontalBox, LineEdit, ListView } from "std-widgets.slint";

export global Theme {
    out property <color> bg: #0B1120;
    out property <color> surface: #131A2E;
    out property <color> text: #F8FAFC;
    out property <color> text-muted: #94A3B8;
    out property <color> accent: #10B981;
}

export component App inherits Window {
    title: "EduPlatform";
    background: Theme.bg;
    preferred-width: 390px;
    preferred-height: 844px;

    in-out property <string> boot-error: "";
    in-out property <bool> boot-loading: false;
    in-out property <string> contact: "";
    in-out property <string> otp: "";
    in-out property <int> step: 0;
    in-out property <string> user-name: "";

    // Auth
    callback request-otp(string);
    callback verify-otp(string);
    callback logout();

    // Data
    callback load-home();
    callback load-tests();
    callback load-qa();
    callback start-test(string);
    callback submit-test(string, string);
    callback post-question(string, string);
    callback load-chapters(string);
    callback load-lessons(string);

    // Navigation
    callback navigate-home();
    callback navigate-auth();
    callback show-otp-screen();
    callback show-test-runner();
    callback show-test-result();
    callback close-question-sheet();

    if step == 0 : Rectangle {
        background: Theme.bg;
        VerticalBox {
            spacing: 24px;
            padding: 32px;

            Text {
                text: "EduPlatform";
                color: Theme.text;
                font-size: 32px;
                font-weight: 800;
                horizontal-alignment: center;
            }
            Text {
                text: "One platform. Endless learning.";
                color: Theme.text-muted;
                font-size: 14px;
                horizontal-alignment: center;
            }

            LineEdit {
                placeholder-text: "Email or phone";
                text <=> root.contact;
            }

            Button {
                text: "Send code";
                enabled: root.contact != "";
                clicked => {
                    root.request-otp(root.contact);
                    root.step = 1;
                }
            }

            if root.boot-error != "" : Text {
                text: root.boot-error;
                color: #FCA5A5;
                font-size: 12px;
                horizontal-alignment: center;
            }
        }
    }

    if step == 1 : Rectangle {
        background: Theme.bg;
        VerticalBox {
            spacing: 24px;
            padding: 32px;

            Text {
                text: "Verify your identity";
                color: Theme.text;
                font-size: 22px;
                font-weight: 700;
            }
            Text {
                text: "Enter the 6-digit code sent to " + root.contact;
                color: Theme.text-muted;
                font-size: 13px;
                wrap: word-wrap;
            }

            LineEdit {
                placeholder-text: "6-digit code";
                text <=> root.otp;
                input-type: number;
            }

            Button {
                text: "Verify and continue";
                enabled: root.otp.character-count >= 6;
                clicked => {
                    root.verify-otp(root.otp);
                }
            }

            Button {
                text: "Back";
                clicked => { root.step = 0; }
            }
        }
    }

    if step == 2 : Rectangle {
        background: Theme.bg;
        VerticalBox {
            spacing: 24px;
            padding: 32px;

            Text {
                text: "Welcome, " + root.user-name;
                color: Theme.text;
                font-size: 24px;
                font-weight: 700;
            }
            Text {
                text: "You are signed in.";
                color: Theme.text-muted;
                font-size: 14px;
            }

            Button {
                text: "Sign out";
                clicked => {
                    root.logout();
                    root.step = 0;
                }
            }
        }
    }
}
