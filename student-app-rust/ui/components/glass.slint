// Glassmorphism design system — professional, no emojis.
//
// Design principles:
//   1. Deep navy gradient background (#0B1120 → #131A2E → #1E293B)
//   2. Frosted glass cards (rgba(255,255,255,0.06) + border + shadow)
//   3. Emerald accent (#10B981) — single accent, no rainbow
//   4. 14-24px corner radii, 18-24px shadow blur
//   5. System sans-serif typography with tight tracking on headings
//   6. SVG icons (see icon.slint), never emojis
//   7. Subtle motion only — no bouncy animations

import { Theme } from "../app.slint";
import { Icon } from "icon.slint";
import { TouchArea } from "std-widgets.slint";

// ─── GlassCard ─────────────────────────────────────────────────────────────
export component GlassCard inherits Rectangle {
    radius: Theme.radius-lg;
    border-width: 1px;
    border-color: Theme.glass-border;
    background: Theme.glass-bg;
    drop-shadow-blur: 18px;
    drop-shadow-color: rgba(0, 0, 0, 0.35);
    drop-shadow-offset-y: 6px;
}

export component GlassCardStrong inherits Rectangle {
    radius: Theme.radius-lg;
    border-width: 1px;
    border-color: Theme.glass-border;
    background: Theme.glass-bg-strong;
    drop-shadow-blur: 22px;
    drop-shadow-color: rgba(0, 0, 0, 0.45);
    drop-shadow-offset-y: 8px;
}

// ─── AccentButton ──────────────────────────────────────────────────────────
export component AccentButton inherits Rectangle {
    radius: Theme.radius-md;
    background: ta.pressed ? Theme.accent-hover
              : ta.has-hover ? Theme.accent-hover
              : Theme.accent;
    height: 52px;
    min-width: 120px;

    property <string> text <=> label.text;
    property <bool> disabled: false;
    property <length> font-size: 15px;
    property <string> icon: "";

    ta := TouchArea {
        enabled: !root.disabled;
        mouse-cursor: ta.has-hover ? pointer : default;
        clicked: () => { if !root.disabled { root.clicked(); } }
    }

    HorizontalLayout {
        x: 0; y: 0; width: 100%; height: 100%;
        alignment: center;
        spacing: 8px;

        if root.icon != "" {
            Icon {
                icon-name: root.icon;
                color: #FFFFFF;
                width: 18px; height: 18px;
                y: (parent.height - self.height) / 2;
            }
        }
        label := Text {
            text: "Button";
            color: #FFFFFF;
            font-size: root.font-size;
            font-weight: 600;
            vertical-alignment: center;
            y: (parent.height - self.height) / 2;
        }
    }

    callback clicked();
}

// ─── GhostButton ───────────────────────────────────────────────────────────
export component GhostButton inherits Rectangle {
    radius: Theme.radius-md;
    background: ta.pressed ? Theme.glass-bg-strong
              : ta.has-hover ? Theme.glass-bg-strong
              : Theme.glass-bg;
    border-width: 1px;
    border-color: Theme.glass-border;
    height: 48px;
    min-width: 80px;

    property <string> text <=> label.text;
    property <color> text-color: Theme.text-primary;
    property <length> font-size: 14px;
    property <bool> disabled: false;
    property <string> icon: "";

    ta := TouchArea {
        enabled: !root.disabled;
        mouse-cursor: ta.has-hover ? pointer : default;
        clicked: () => { if !root.disabled { root.clicked(); } }
    }

    HorizontalLayout {
        alignment: center;
        spacing: 8px;

        if root.icon != "" {
            Icon {
                icon-name: root.icon;
                color: root.text-color;
                width: 16px; height: 16px;
                y: (parent.height - self.height) / 2;
            }
        }
        label := Text {
            text: "Button";
            color: root.text-color;
            font-size: root.font-size;
            font-weight: 500;
            vertical-alignment: center;
            y: (parent.height - self.height) / 2;
        }
    }

    callback clicked();
}

// ─── GlassTextInput ────────────────────────────────────────────────────────
export component GlassTextInput inherits Rectangle {
    radius: Theme.radius-md;
    background: input.has-focus ? Theme.glass-bg-strong : Theme.glass-bg;
    border-width: 1.5px;
    border-color: input.has-focus ? Theme.accent : Theme.glass-border;
    height: 56px;

    property <string> placeholder;
    property <string> text <=> input.text;
    property <bool> is-password: false;

    input := TextInput {
        x: 16px;
        y: (parent.height - self.preferred-height) / 2;
        width: parent.width - 32px;
        height: self.preferred-height;
        font-size: 15px;
        color: Theme.text-primary;
        selection-foreground-color: #FFFFFF;
        selection-background-color: Theme.accent;
        single-line: true;
        input-type: root.is-password ? InputType.password : InputType.text;
    }

    placeholder-text := Text {
        x: 16px;
        y: (parent.height - self.height) / 2;
        text: root.placeholder;
        color: Theme.text-muted;
        font-size: 15px;
        visible: input.text == "" && !input.has-focus;
    }
}

// ─── OTPInput (6 boxes, professional look) ─────────────────────────────────
export component OTPInput inherits HorizontalLayout {
    spacing: 8px;
    height: 56px;

    property <string> value: box1.text + box2.text + box3.text + box4.text + box5.text + box6.text;

    box1 := OTPBox { index: 1; }
    box2 := OTPBox { index: 2; }
    box3 := OTPBox { index: 3; }
    box4 := OTPBox { index: 4; }
    box5 := OTPBox { index: 5; }
    box6 := OTPBox { index: 6; }
}

component OTPBox inherits Rectangle {
    radius: Theme.radius-md;
    background: input.has-focus ? Theme.glass-bg-strong : Theme.glass-bg;
    border-width: 1.5px;
    border-color: input.has-focus ? Theme.accent : Theme.glass-border;
    width: 48px;
    height: 56px;

    property <int> index: 1;
    property <string> text <=> input.text;

    input := TextInput {
        x: 0;
        y: (parent.height - self.preferred-height) / 2;
        width: parent.width;
        height: self.preferred-height;
        font-size: 22px;
        font-weight: 700;
        color: Theme.text-primary;
        horizontal-alignment: center;
        input-type: InputType.number;
        maximum-length: 1;
        single-line: true;
    }
}

// ─── BottomNav (floating glass with SVG icons) ─────────────────────────────
export component BottomNav inherits Rectangle {
    width: 100%;
    height: 88px;
    background: transparent;

    in property <int> current: 0;
    callback navigate(int);

    container := Rectangle {
        x: 16px;
        y: 8px;
        width: parent.width - 32px;
        height: 64px;
        radius: Theme.radius-xl;
        background: Theme.glass-bg-strong;
        border-width: 1px;
        border-color: Theme.glass-border;
        drop-shadow-blur: 24px;
        drop-shadow-color: rgba(0, 0, 0, 0.4);
        drop-shadow-offset-y: -4px;

        HorizontalLayout {
            x: 0; y: 0; width: 100%; height: 100%;
            alignment: space-around;

            NavItem {
                label: "Home";
                icon-name: "home";
                active: root.current == 0;
                clicked: () => { root.navigate(0); }
            }
            NavItem {
                label: "Learn";
                icon-name: "book";
                active: root.current == 1;
                clicked: () => { root.navigate(1); }
            }
            NavItem {
                label: "Tests";
                icon-name: "test";
                active: root.current == 2;
                clicked: () => { root.navigate(2); }
            }
            NavItem {
                label: "Q&A";
                icon-name: "chat";
                active: root.current == 3;
                clicked: () => { root.navigate(3); }
            }
            NavItem {
                label: "Profile";
                icon-name: "user";
                active: root.current == 4;
                clicked: () => { root.navigate(4); }
            }
        }
    }
}

component NavItem inherits Rectangle {
    width: 64px;
    height: 100%;
    background: transparent;

    property <string> label;
    property <string> icon-name;
    property <bool> active: false;
    callback clicked();

    ta := TouchArea {
        mouse-cursor: ta.has-hover ? pointer : default;
        clicked: () => { root.clicked(); }
    }

    VerticalLayout {
        alignment: center;
        spacing: 4px;

        Icon {
            icon-name: root.icon-name;
            color: root.active ? Theme.accent : Theme.text-secondary;
            width: 22px; height: 22px;
            horizontal-stretch: 0;
        }
        Text {
            text: root.label;
            font-size: 10px;
            font-weight: root.active ? 700 : 500;
            horizontal-alignment: center;
            color: root.active ? Theme.accent : Theme.text-muted;
        }
    }
}

// ─── LoadingOverlay ────────────────────────────────────────────────────────
export component LoadingOverlay inherits Rectangle {
    width: 100%;
    height: 100%;
    background: rgba(11, 17, 32, 0.7);

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 120px;
        height: 120px;
        radius: Theme.radius-lg;
        background: Theme.glass-bg-strong;
        border-width: 1px;
        border-color: Theme.glass-border;

        // Spinner ring
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2 - 12px;
            width: 40px;
            height: 40px;
            radius: self.width / 2;
            border-width: 3px;
            border-color: Theme.glass-border;

            // Spinning arc indicator (a small dot on the ring)
            Rectangle {
                width: 6px;
                height: 6px;
                x: parent.width / 2 - self.width / 2;
                y: 0;
                radius: self.width / 2;
                background: Theme.accent;
            }
        }

        Text {
            text: "Loading";
            color: Theme.text-secondary;
            font-size: 12px;
            horizontal-alignment: center;
            y: parent.height - 28px;
            width: parent.width;
        }
    }
}

// ─── ErrorToast ────────────────────────────────────────────────────────────
export component ErrorToast inherits Rectangle {
    width: 100%;
    height: 60px;
    background: transparent;

    in property <string> message;

    container := Rectangle {
        x: 16px;
        y: 16px;
        width: parent.width - 32px;
        height: 52px;
        radius: Theme.radius-md;
        background: rgba(239, 68, 68, 0.15);
        border-width: 1px;
        border-color: rgba(239, 68, 68, 0.3);

        HorizontalLayout {
            x: 16px; y: 0;
            width: parent.width - 32px;
            height: parent.height;
            spacing: 10px;

            Icon {
                icon-name: "x";
                color: #FCA5A5;
                width: 18px; height: 18px;
                y: (parent.height - self.height) / 2;
            }
            Text {
                text: root.message;
                color: #FCA5A5;
                font-size: 13px;
                vertical-alignment: center;
                width: parent.width - 28px;
                overflow: elide;
            }
        }
    }
}

// ─── SectionTitle / Subtitle ───────────────────────────────────────────────
export component SectionTitle inherits Text {
    color: Theme.text-primary;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.4px;
}

export component Subtitle inherits Text {
    color: Theme.text-secondary;
    font-size: 14px;
    font-weight: 400;
}

// ─── StatChip (clean, minimal — icon + value + label) ──────────────────────
export component StatChip inherits Rectangle {
    radius: Theme.radius-md;
    background: Theme.glass-bg;
    border-width: 1px;
    border-color: Theme.glass-border;
    height: 92px;

    property <string> icon-name: "book";
    property <string> value: "0";
    property <string> label: "Stat";
    property <color> icon-color: Theme.accent;

    VerticalLayout {
        alignment: center;
        spacing: 6px;
        padding: 14px;

        Icon {
            icon-name: root.icon-name;
            color: root.icon-color;
            width: 20px; height: 20px;
            horizontal-stretch: 0;
        }
        Text {
            text: root.value;
            color: Theme.text-primary;
            font-size: 22px;
            font-weight: 700;
        }
        Text {
            text: root.label;
            color: Theme.text-muted;
            font-size: 11px;
        }
    }
}
