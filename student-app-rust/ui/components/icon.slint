// Professional icon system — pure SVG paths, no emojis.
// All icons inherit `currentColor` so they tint to the parent text color.
//
// Usage: Icon { icon-name: "home"; color: Theme.text-primary; size: 24px; }

import { Theme } from "../app.slint";

export component Icon inherits Rectangle {
    width: 24px;
    height: 24px;
    background: transparent;

    in property <string> icon-name: "home";
    property <color> color: Theme.text-primary;

    // Each icon is drawn with a Path. We switch based on icon-name.
    // Stroke-based icons (Feather/Lucide style) — 2px stroke, round caps.
    canvas := Path {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        fill: transparent;
        stroke: root.color;
        stroke-width: 2px;
        stroke-linecap: round;
        stroke-linejoin: round;
        commands: root.icon-name == "home" ? "M 3 11 L 12 3 L 21 11 M 5 10 L 5 21 L 19 21 L 19 10 M 9 21 L 9 14 L 15 14 L 15 21"
                  : root.icon-name == "book" ? "M 4 4 L 4 20 Q 4 20 6 20 L 20 20 L 20 4 L 6 4 Q 4 4 4 4 M 4 4 Q 4 4 6 4 L 6 20 M 8 8 L 17 8 M 8 12 L 17 12"
                  : root.icon-name == "test" ? "M 5 3 L 19 3 L 19 21 L 5 21 Z M 8 8 L 16 8 M 8 12 L 16 12 M 8 16 L 13 16"
                  : root.icon-name == "chat" ? "M 21 11 Q 21 16 16 19 L 14 21 L 12 19 Q 5 19 5 11 Q 5 5 12 5 Q 21 5 21 11 Z M 9 11 L 9 11 M 13 11 L 13 11 M 17 11 L 17 11"
                  : root.icon-name == "user" ? "M 12 12 M 5 21 Q 5 14 12 14 Q 19 14 19 21 M 12 11 M 8 7 Q 8 4 12 4 Q 16 4 16 7 Q 16 11 12 11 Q 8 11 8 7"
                  : root.icon-name == "mail" ? "M 3 5 L 21 5 L 21 19 L 3 19 Z M 3 5 L 12 13 L 21 5"
                  : root.icon-name == "phone" ? "M 5 4 L 9 4 L 11 9 L 8 11 Q 10 14 13 16 L 15 13 L 20 15 L 20 19 Q 20 20 19 20 Q 10 20 5 11 Q 4 8 4 5 Q 4 4 5 4"
                  : root.icon-name == "shield" ? "M 12 3 L 20 6 L 20 12 Q 20 18 12 21 Q 4 18 4 12 L 4 6 Z M 9 12 L 11 14 L 15 10"
                  : root.icon-name == "arrow-right" ? "M 5 12 L 19 12 M 13 6 L 19 12 L 13 18"
                  : root.icon-name == "arrow-left" ? "M 19 12 L 5 12 M 11 6 L 5 12 L 11 18"
                  : root.icon-name == "check" ? "M 5 12 L 10 17 L 19 7"
                  : root.icon-name == "x" ? "M 6 6 L 18 18 M 18 6 L 6 18"
                  : root.icon-name == "clock" ? "M 12 3 Q 21 3 21 12 Q 21 21 12 21 Q 3 21 3 12 Q 3 3 12 3 M 12 7 L 12 12 L 16 14"
                  : root.icon-name == "play" ? "M 6 4 L 20 12 L 6 20 Z"
                  : root.icon-name == "file" ? "M 6 3 L 14 3 L 20 9 L 20 21 L 6 21 Z M 14 3 L 14 9 L 20 9 M 9 13 L 17 13 M 9 17 L 17 17"
                  : root.icon-name == "trophy" ? "M 8 4 L 16 4 L 16 12 Q 16 14 12 14 Q 8 14 8 12 Z M 5 5 L 8 5 L 8 10 Q 5 10 5 7 M 19 5 L 16 5 L 16 10 Q 19 10 19 7 M 10 14 L 10 18 L 14 18 L 14 14 M 8 21 L 16 21"
                  : root.icon-name == "flame" ? "M 12 3 Q 8 8 8 12 Q 8 17 12 17 Q 16 17 16 12 Q 16 8 12 3 M 12 21 Q 6 21 6 15 Q 6 13 8 11"
                  : root.icon-name == "logout" ? "M 9 4 L 4 4 L 4 20 L 9 20 M 16 12 L 9 12 M 16 12 L 13 9 M 16 12 L 13 15 M 14 7 Q 18 9 18 12 Q 18 15 14 17"
                  : root.icon-name == "plus" ? "M 12 5 L 12 19 M 5 12 L 19 12"
                  : root.icon-name == "chevron-right" ? "M 9 6 L 15 12 L 9 18"
                  : root.icon-name == "chevron-down" ? "M 6 9 L 12 15 L 18 9"
                  : root.icon-name == "graduation" ? "M 2 9 L 12 4 L 22 9 L 12 14 Z M 6 11 L 6 17 Q 12 20 18 17 L 18 11 M 22 9 L 22 14"
                  : "";
    }
}
